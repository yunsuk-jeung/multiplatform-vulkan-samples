# direnv: auto-load the locally-installed Vulkan SDK on entering this directory.
# Run `direnv allow` once to trust this file. Install the SDK with:
#   scripts/setup-vulkan-sdk.sh

# Pick the highest installed SDK version under third_party/vulkan-sdk/.
sdk_dir=$(find "$PWD/third_party/vulkan-sdk" -maxdepth 1 -mindepth 1 -type d -name '1.*' 2>/dev/null | sort -V | tail -n1)

if [ -n "$sdk_dir" ] && [ -f "$sdk_dir/setup-env.sh" ]; then
  # setup-env.sh locates itself via BASH_SOURCE, so sourcing it here works.
  source "$sdk_dir/setup-env.sh"
  watch_file "$sdk_dir/setup-env.sh"
  log_status "Vulkan SDK loaded: $(basename "$sdk_dir")"
else
  log_error "Vulkan SDK not found under third_party/vulkan-sdk/. Run: scripts/setup-vulkan-sdk.sh"
fi
